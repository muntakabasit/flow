// ═══════════════════════════════════════════════════════════
// STATE MACHINE — single transition point
// ═══════════════════════════════════════════════════════════
// Valid state transitions (state machine)
const VALID_TRANSITIONS = {
  [S.IDLE]:        [S.CONNECTING, S.OFFLINE],
  [S.CONNECTING]:  [S.READY, S.OFFLINE, S.FAILED],
  [S.READY]:       [S.LISTENING, S.OFFLINE, S.FAILED],
  [S.LISTENING]:   [S.TRANSLATING, S.READY, S.OFFLINE, S.FAILED],
  [S.TRANSLATING]: [S.SPEAKING, S.READY, S.OFFLINE, S.FAILED],
  [S.SPEAKING]:    [S.READY, S.OFFLINE, S.FAILED],
  [S.OFFLINE]:     [S.CONNECTING, S.IDLE],
  [S.FAILED]:      [S.CONNECTING, S.IDLE],
};

function transition(next) {
  // Guard: no-op if already in state
  if (next === state) return;

  const prev = state;

  // CRITICAL: Validate transition is allowed
  const allowed = VALID_TRANSITIONS[prev] || [];
  if (!allowed.includes(next)) {
    diagLog(`❌ INVALID: ${prev} → ${next} (allowed: ${allowed.join(', ')})`, 'err');
    return;  // Reject invalid transition
  }

  state = next;
  diagLog(`${prev} → ${next}`, 'ok');

  // pill
  $pill.dataset.state = next;
  $pillLabel.textContent = next;

  // reconnect banner
  $reconnBar.classList.toggle('show', next === S.OFFLINE);

  // mic button visual
  if (next === S.OFFLINE) {
    $micBtn.dataset.vis = 'disabled';
    $micLabel.textContent = 'offline';
  } else if (next === S.IDLE) {
    $micBtn.dataset.vis = 'idle';
    $micLabel.textContent = '';
  } else if (next === S.CONNECTING) {
    $micBtn.dataset.vis = 'disabled';
    $micLabel.textContent = 'connecting';
  } else if (next === S.READY) {
    $micBtn.dataset.vis = 'idle';
    $micLabel.textContent = 'ready';
  } else if (next === S.LISTENING) {
    $micBtn.dataset.vis = 'live';
    $micLabel.textContent = 'listening';
  } else if (next === S.TRANSLATING) {
    $micBtn.dataset.vis = 'live';
    $micLabel.textContent = 'translating';
  } else if (next === S.SPEAKING) {
    $micBtn.dataset.vis = 'live';
    $micLabel.textContent = 'speaking';
  }

  // mic aria
  const isLive = [S.LISTENING, S.TRANSLATING, S.SPEAKING].includes(next);
  $micBtn.setAttribute('aria-checked', isLive);
  $micBtn.setAttribute('aria-label', isLive ? 'Stop interpreting' : 'Start interpreting');

  // waveform
  if (isLive) startWave(); else stopWave();

  // on offline/failed: stop mic cleanly
  if (next === S.OFFLINE || next === S.FAILED) {
    killMic();
    killPlayback();
  }

  // cleanup keepalive timers on disconnect states
  if (next === S.OFFLINE || next === S.FAILED || next === S.IDLE) {
    if (keepaliveTimer) clearTimeout(keepaliveTimer);
    if (clientKeepaliveTask) clearInterval(clientKeepaliveTask);
  }
}

// ═══════════════════════════════════════════════════════════
// AUDIO UTILITIES
// ═══════════════════════════════════════════════════════════
function resample(inp, rateIn, rateOut) {
  if (rateIn === rateOut) return inp;
  const ratio = rateIn / rateOut;
  const len = Math.round(inp.length / ratio);
  const out = new Float32Array(len);
  for (let i = 0; i < len; i++) {
    const si = i * ratio, lo = Math.floor(si);
    const hi = Math.min(lo+1, inp.length-1), f = si - lo;
    out[i] = inp[lo]*(1-f) + inp[hi]*f;
  }
  return out;
}
function f32toI16(f32) {
  const i16 = new Int16Array(f32.length);
  for (let i = 0; i < f32.length; i++) {
    const s = Math.max(-1, Math.min(1, f32[i]));
    i16[i] = s < 0 ? s*0x8000 : s*0x7FFF;
  }
  return i16;
}
function i16toB64(i16) {
  const bytes = new Uint8Array(i16.buffer);
  const C = 8192; let bin = '';
  for (let i = 0; i < bytes.length; i += C) {
    bin += String.fromCharCode.apply(null, bytes.subarray(i, Math.min(i+C, bytes.length)));
  }
  return btoa(bin);
}
function timeStr() {
  return new Date().toLocaleTimeString('en-US', {hour12:false, hour:'2-digit', minute:'2-digit', second:'2-digit'});
}

