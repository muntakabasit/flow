<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="theme-color" content="#08090c">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="Flow">
  <link rel="manifest" href="/static/manifest.json">
  <link rel="apple-touch-icon" href="/static/icon-192.png">
  <title>Flow</title>
  <style>
    /* ═══════════════════════════════════════════════════════
       FLOW — Operator-grade live interpreter
       Design tokens + complete UI
       ═══════════════════════════════════════════════════════ */
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box;
      -webkit-tap-highlight-color:transparent; }

    :root {
      /* ── Palette ─────────────────────────────── */
      --bg:        #08090c;
      --surface:   #0e1017;
      --surface2:  #14161e;
      --surface3:  #1b1e28;
      --border:    #1f2231;
      --border-hi: #2a2e3d;

      --text:      #e8eaf0;
      --text-2:    #9399ad;
      --text-3:    #5c6178;

      /* accent: warm amber — distinctive, not default blue/teal */
      --accent:    #e0a846;
      --accent-dim:#7a5e28;
      --accent-bg: rgba(224,168,70,0.08);
      --accent-glow: rgba(224,168,70,0.15);

      --green:     #34d399;
      --green-dim: #16503b;
      --red:       #f87171;
      --red-dim:   #5c2323;
      --amber:     #fbbf24;

      --radius:    10px;
      --radius-lg: 16px;
      --safe-top:  env(safe-area-inset-top, 0px);
      --safe-bot:  env(safe-area-inset-bottom, 0px);
      --font:      'SF Pro Text', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      --font-mono: 'SF Mono', 'Menlo', 'Consolas', monospace;
    }

    html, body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      height: 100%; overflow: hidden;
      touch-action: manipulation;
      -webkit-user-select: none; user-select: none;
    }

    /* ═══ APP SHELL ═══════════════════════════════════════ */
    .app {
      display: flex; flex-direction: column;
      height: 100%;
      padding-top: var(--safe-top);
      padding-bottom: var(--safe-bot);
    }

    /* ═══ HEADER ═════════════════════════════════════════ */
    .hdr {
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 16px 8px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
      background: linear-gradient(180deg, rgba(14,16,23,1) 0%, var(--bg) 100%);
    }
    .hdr-brand {
      display: flex; align-items: baseline; gap: 8px;
    }
    .hdr-logo {
      font-size: 18px; font-weight: 800;
      letter-spacing: 4px; text-transform: uppercase;
      background: linear-gradient(135deg, var(--accent) 0%, #f0c66e 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hdr-tag {
      font-size: 10px; font-weight: 500;
      color: var(--text-3); letter-spacing: 1.5px;
      text-transform: uppercase;
    }
    .hdr-right { display: flex; align-items: center; gap: 8px; }

    /* ── State pill ─────────────────────────────── */
    .pill {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 3px 10px 3px 8px;
      border-radius: 20px;
      background: var(--surface2);
      border: 1px solid var(--border);
      font-size: 10px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 1px;
      color: var(--text-3);
      transition: all .35s ease;
    }
    .pill-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--text-3);
      transition: background .3s, box-shadow .3s;
    }
    /* State variants */
    .pill[data-state="connecting"]  { color: var(--amber); }
    .pill[data-state="connecting"] .pill-dot { background: var(--amber); animation: blink-dot 1s infinite; }
    .pill[data-state="ready"]      { color: var(--green); border-color: var(--green-dim); }
    .pill[data-state="ready"] .pill-dot { background: var(--green); box-shadow: 0 0 6px var(--green); }
    .pill[data-state="listening"]  { color: var(--green); border-color: var(--green-dim); }
    .pill[data-state="listening"] .pill-dot { background: var(--green); animation: pulse-dot 1.8s infinite; }
    .pill[data-state="translating"] { color: var(--accent); border-color: var(--accent-dim); }
    .pill[data-state="translating"] .pill-dot { background: var(--accent); animation: blink-dot .6s infinite; }
    .pill[data-state="speaking"]   { color: var(--accent); border-color: var(--accent-dim); }
    .pill[data-state="speaking"] .pill-dot { background: var(--accent); box-shadow: 0 0 8px var(--accent); }
    .pill[data-state="offline"]    { color: var(--red); border-color: var(--red-dim); }
    .pill[data-state="offline"] .pill-dot { background: var(--red); }

    @keyframes pulse-dot {
      0%,100% { opacity:1; transform:scale(1); }
      50% { opacity:.4; transform:scale(.75); }
    }
    @keyframes blink-dot {
      0%,100% { opacity:1; } 50% { opacity:.25; }
    }

    /* ═══ RECONNECT BANNER ═══════════════════════════════ */
    .reconnect-banner {
      display: none; align-items: center; justify-content: center; gap: 10px;
      padding: 8px 16px;
      background: var(--red-dim);
      border-bottom: 1px solid rgba(248,113,113,.3);
      font-size: 12px; font-weight: 600; color: var(--red);
      flex-shrink: 0;
    }
    .reconnect-banner.show { display: flex; animation: slideDown .25s ease-out; }
    .reconnect-banner button {
      background: rgba(248,113,113,.15); border: 1px solid rgba(248,113,113,.3);
      color: var(--red); font-size: 11px; font-weight: 700; font-family: var(--font);
      padding: 3px 12px; border-radius: 6px; cursor: pointer;
      text-transform: uppercase; letter-spacing: .5px;
    }
    .reconnect-banner button:active { transform: scale(.95); }
    @keyframes slideDown { from { transform: translateY(-100%); opacity:0; } to { transform: translateY(0); opacity:1; } }

    /* ═══ LANG BAR ═══════════════════════════════════════ */
    .lang-bar {
      display: flex; align-items: center; justify-content: center; gap: 10px;
      padding: 6px 16px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .lang-tag {
      font-size: 11px; font-weight: 600; color: var(--text-3);
      letter-spacing: .5px; text-transform: uppercase;
    }
    .lang-arrow { color: var(--accent); font-size: 13px; opacity: .6; }

    /* ═══ TRANSCRIPT ═════════════════════════════════════ */
    .transcript-wrap {
      flex: 1; display: flex; flex-direction: column;
      overflow: hidden; position: relative;
    }
    .transcript-toolbar {
      display: flex; align-items: center; justify-content: space-between;
      padding: 4px 16px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0; min-height: 28px;
    }
    .transcript-toolbar span {
      font-size: 10px; font-weight: 600; color: var(--text-3);
      text-transform: uppercase; letter-spacing: 1px;
    }
    .autoscroll-toggle {
      display: flex; align-items: center; gap: 5px;
      font-size: 10px; color: var(--text-3); cursor: pointer;
      background: none; border: none; font-family: var(--font);
      padding: 2px 6px; border-radius: 4px;
    }
    .autoscroll-toggle:hover { background: var(--surface2); }
    .autoscroll-toggle .check { color: var(--green); }

    .transcript {
      flex: 1; overflow-y: auto; padding: 8px 0;
      -webkit-overflow-scrolling: touch;
      scroll-behavior: smooth;
    }

    /* Each turn = a row with source | translation */
    .t-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      border-bottom: 1px solid var(--border);
      animation: fadeRow .2s ease-out;
      font-size: 14px; line-height: 1.55;
    }
    @keyframes fadeRow {
      from { opacity:0; transform:translateY(4px); }
      to { opacity:1; transform:translateY(0); }
    }

    .t-cell {
      padding: 8px 14px;
      min-height: 36px;
      display: flex; flex-direction: column; gap: 3px;
    }
    .t-src {
      color: var(--text-2);
      border-right: 1px solid var(--border);
    }
    .t-tgt {
      color: var(--text);
      font-weight: 500;
    }
    .t-tgt.streaming::after {
      content: "▍"; color: var(--accent); animation: caret .8s step-end infinite;
    }
    @keyframes caret { 50% { opacity:0; } }
    .t-ts {
      font-size: 9px; color: var(--text-3); font-family: var(--font-mono);
    }
    .t-speaker {
      font-size: 9px; font-weight: 700; color: var(--accent); letter-spacing: 1px;
      text-transform: uppercase;
    }
    .t-src .t-speaker { color: var(--text-3); }
    .t-tgt .t-speaker { color: var(--accent); }
    .t-text {
      font-size: 14px; line-height: 1.55;
    }
    .t-confidence {
      font-size: 8px; color: var(--text-3);
      display: inline-flex; gap: 3px; align-items: center;
    }
    .t-confidence.high { color: var(--green); }
    .t-confidence.med { color: var(--amber); }
    .t-confidence.low { color: var(--red); }

    .t-system {
      grid-column: 1 / -1;
      text-align: center;
      font-size: 11px; color: var(--text-3);
      padding: 4px 14px;
      font-style: italic;
    }

    /* large text mode */
    .app.large-text .t-tgt { font-size: 20px; }
    .app.large-text .t-src { font-size: 16px; }

    /* ═══ CONTROL DOCK ═══════════════════════════════════ */
    .dock {
      flex-shrink: 0;
      border-top: 1px solid var(--border);
      background: linear-gradient(180deg, var(--bg) 0%, #060710 100%);
      padding: 12px 16px 16px;
      display: flex; flex-direction: column; align-items: center; gap: 10px;
    }

    /* waveform */
    .wave {
      display: flex; align-items: center; justify-content: center;
      gap: 2px; height: 20px; opacity: 0; transition: opacity .3s;
    }
    .wave.on { opacity: 1; }
    .wave-bar {
      width: 2.5px; border-radius: 2px;
      background: var(--accent); height: 4px;
      transition: height 80ms ease;
    }

    /* mic row */
    .mic-row {
      display: flex; align-items: center; gap: 20px;
    }

    /* THE MIC BUTTON */
    .mic {
      position: relative;
      width: 72px; height: 72px; border-radius: 50%;
      border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      outline: none; -webkit-appearance: none;
      transition: all .25s ease;
    }
    .mic svg { width: 28px; height: 28px; transition: fill .25s; }
    .mic-ring {
      position: absolute; inset: -6px; border-radius: 50%;
      border: 2px solid var(--accent); opacity: 0;
      pointer-events: none;
    }

    /* mic states */
    .mic[data-vis="idle"] {
      background: var(--surface3); border: 2px solid var(--border-hi);
    }
    .mic[data-vis="idle"] svg { fill: var(--text-2); }
    .mic[data-vis="idle"]:hover { border-color: var(--accent-dim); }
    .mic[data-vis="idle"]:hover svg { fill: var(--accent); }

    .mic[data-vis="live"] {
      background: var(--accent); border: 2px solid var(--accent);
      box-shadow: 0 0 30px var(--accent-glow);
    }
    .mic[data-vis="live"] svg { fill: var(--bg); }
    .mic[data-vis="live"] .mic-ring {
      opacity: .4; animation: ring-out 2s ease-out infinite;
    }

    .mic[data-vis="disabled"] {
      background: var(--surface2); border: 2px solid var(--border);
      cursor: not-allowed; opacity: .4;
    }
    .mic[data-vis="disabled"] svg { fill: var(--text-3); }

    .mic:active:not([data-vis="disabled"]) { transform: scale(.92); }

    @keyframes ring-out {
      0% { transform:scale(1); opacity:.4; }
      100% { transform:scale(1.6); opacity:0; }
    }

    /* status label under mic */
    .mic-label {
      font-size: 11px; font-weight: 600;
      color: var(--text-3); text-transform: uppercase;
      letter-spacing: 1px; text-align: center;
      margin-top: -2px; min-height: 16px;
    }

    /* side actions */
    .side-btn {
      background: none; border: none; cursor: pointer;
      color: var(--text-3); font-size: 10px; font-weight: 600;
      display: flex; flex-direction: column; align-items: center; gap: 3px;
      padding: 6px 8px; border-radius: 8px; min-width: 48px;
      font-family: var(--font); text-transform: uppercase; letter-spacing: .5px;
      transition: all .15s;
    }
    .side-btn svg { width: 20px; height: 20px; fill: var(--text-3); transition: fill .15s; }
    .side-btn.on svg { fill: var(--accent); }
    .side-btn.on { color: var(--accent); }
    .side-btn:active { transform: scale(.9); }

    /* ═══ DIAGNOSTICS PANEL ══════════════════════════════ */
    .diag {
      flex-shrink: 0;
      max-height: 0; overflow: hidden;
      transition: max-height .3s ease;
      border-top: 1px solid var(--border);
      background: var(--surface);
    }
    .diag.open { max-height: 200px; }
    .diag-inner {
      padding: 8px 14px;
      font-family: var(--font-mono);
      font-size: 10px; line-height: 1.6;
      color: var(--text-3);
      max-height: 180px; overflow-y: auto;
    }
    .diag-line { margin-bottom: 1px; }
    .diag-line.err { color: var(--red); }
    .diag-line.ok  { color: var(--green); }

    /* ═══ MEDIA QUERIES ══════════════════════════════════ */
    @media (pointer: coarse) {
      .mic { width: 80px; height: 80px; }
      .mic svg { width: 32px; height: 32px; }
    }
    @media (max-height: 580px) {
      .mic { width: 64px; height: 64px; }
      .mic svg { width: 24px; height: 24px; }
      .dock { padding: 8px 16px 10px; gap: 6px; }
    }
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: .01ms !important; transition-duration: .01ms !important;
      }
    }
    :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  </style>
</head>
<body>
<div class="app" id="app">

  <!-- ═══ HEADER ═══ -->
  <header class="hdr">
    <div class="hdr-brand">
      <div class="hdr-logo">Flow</div>
      <div class="hdr-tag">Interpreter</div>
    </div>
    <div class="hdr-right">
      <div class="pill" id="pill" data-state="idle" role="status" aria-live="polite">
        <span class="pill-dot"></span>
        <span id="pillLabel">idle</span>
      </div>
    </div>
  </header>

  <!-- ═══ RECONNECT BANNER ═══ -->
  <div class="reconnect-banner" id="reconnBar">
    <span id="reconnMsg">Reconnecting&hellip;</span>
    <button id="reconnBtn" aria-label="Reconnect now">Reconnect</button>
  </div>

  <!-- ═══ LANGUAGE BAR ═══ -->
  <div class="lang-bar" aria-label="Translation direction">
    <span class="lang-tag">English</span>
    <span class="lang-arrow">&#8644;</span>
    <span class="lang-tag">Portugu&ecirc;s</span>
  </div>

  <!-- ═══ TRANSCRIPT ═══ -->
  <div class="transcript-wrap">
    <div class="transcript-toolbar">
      <span>Transcript</span>
      <button class="autoscroll-toggle" id="scrollToggle" aria-pressed="true">
        <span class="check" id="scrollCheck">&#10003;</span> Auto-scroll
      </button>
    </div>
    <div class="transcript" id="transcript" role="log" aria-label="Translation log" aria-live="polite"></div>
  </div>

  <!-- ═══ DIAGNOSTICS (collapsible) ═══ -->
  <div class="diag" id="diag">
    <div class="diag-inner" id="diagInner"></div>
  </div>

  <!-- ═══ CONTROL DOCK ═══ -->
  <div class="dock">
    <!-- waveform -->
    <div class="wave" id="wave" aria-hidden="true"></div>

    <div class="mic-row">
      <!-- audio toggle -->
      <button class="side-btn on" id="audioBtn" aria-label="Toggle spoken output" aria-pressed="true">
        <svg viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>
        <span>Audio</span>
      </button>

      <!-- MIC COLUMN -->
      <div style="display:flex;flex-direction:column;align-items:center;gap:4px;">
        <button class="mic" id="micBtn" data-vis="idle"
                aria-label="Start interpreting" role="switch" aria-checked="false" tabindex="0">
          <div class="mic-ring"></div>
          <svg viewBox="0 0 24 24"><path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3z"/><path d="M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z"/></svg>
        </button>
        <div class="mic-label" id="micLabel"></div>
      </div>

      <!-- diag + text-size -->
      <button class="side-btn" id="diagBtn" aria-label="Toggle diagnostics" aria-pressed="false">
        <svg viewBox="0 0 24 24"><path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9 1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg>
        <span>Log</span>
      </button>

      <!-- Settings button -->
      <button class="side-btn" id="settingsBtn" aria-label="Voice Activity Detection settings" aria-pressed="false">
        <svg viewBox="0 0 24 24"><path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l1.72-1.35c.15-.12.19-.34.1-.51l-1.63-2.83c-.12-.22-.37-.29-.59-.22l-2.03.8c-.42-.32-.9-.6-1.44-.78l-.3-2.16c-.04-.24-.24-.41-.48-.41h-3.27c-.24 0-.43.17-.47.41l-.3 2.16c-.54.18-1.02.46-1.44.78l-2.03-.8c-.22-.09-.47 0-.59.22L2.74 8.87c-.1.17-.06.39.1.51l1.72 1.35c-.05.3-.07.62-.07.94s.02.64.07.94l-1.72 1.35c-.15.12-.19.34-.1.51l1.63 2.83c.12.22.37.29.59.22l2.03-.8c.42.32.9.6 1.44.78l.3 2.16c.05.24.24.41.48.41h3.27c.24 0 .44-.17.47-.41l.3-2.16c.54-.18 1.02-.46 1.44-.78l2.03.8c.22.09.47 0 .59-.22l1.63-2.83c.1-.17.06-.39-.1-.51l-1.72-1.35zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg>
        <span>VAD</span>
      </button>

      <!-- Manual OFF button -->
      <button class="side-btn" id="offBtn" aria-label="Manually stop session" aria-pressed="false">
        <svg viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z"/></svg>
        <span>OFF</span>
      </button>
    </div>
  </div>
</div>

<script>
/* ═══════════════════════════════════════════════════════════
   FLOW CLIENT — State machine, reconnect, operator-grade
   ═══════════════════════════════════════════════════════════ */
'use strict';

const RATE = 24000;                // wire sample rate
const BACKOFF = [300,600,1200,2400,4800,8000,15000]; // exponential backoff with jitter (ms)
const MAX_BACKOFF_ATTEMPTS = 10;   // give up after 10 attempts, show "tap to reconnect"
const STABLE_MS = 2000;            // connection must hold this long to reset backoff
const KEEPALIVE_TIMEOUT_DEFAULT = 60000;   // default: if no pong in 60s, die socket
const KEEPALIVE_INTERVAL = 20000;  // client sends keepalive ping every 20s
let KEEPALIVE_TIMEOUT = KEEPALIVE_TIMEOUT_DEFAULT;  // will be updated by server
const WAVE_N = 15;                 // number of waveform bars

// ── STATE ENUM ────────────────────────────────────────────
const S = Object.freeze({
  IDLE:        'idle',
  CONNECTING:  'connecting',
  READY:       'ready',
  LISTENING:   'listening',
  TRANSLATING: 'translating',
  SPEAKING:    'speaking',
  RECONNECTING: 'reconnecting',
  OFFLINE:     'offline',
  FAILED:      'failed',
});

// ── APP STATE (single source of truth) ────────────────────
let state      = S.IDLE;
let ws         = null;
let audioCtx   = null;
let mediaStream= null;
let processor  = null;
let playCtx    = null;
let audioQ     = [];

// ── CLIENT-SIDE VAD (Voice Activity Detection) ────────────────────
// RMS-based endpointing with hysteresis
let vad = {
  // Settings (persisted in localStorage)
  sensitivity: 0.5,        // 0.0 (sensitive) → 1.0 (insensitive)
  endDelayMs: 650,         // silence duration before finalization

  // Runtime state
  rmsSmoothed: 0,          // smoothed RMS energy
  isSpeaking: false,       // speech detected (hysteresis)
  silenceStart: null,      // when silence began

  // Thresholds (derived from sensitivity)
  get speechStartThreshold() {
    // Lower = more sensitive. Range: 0.004 (max sensitive) → 0.015 (min sensitive)
    return 0.004 + this.sensitivity * 0.011;
  },
  get speechStopThreshold() {
    // Hysteresis: stop threshold lower than start threshold
    return this.speechStartThreshold * 0.7;
  },

  // Update RMS every frame
  updateRMS(audioFrame) {
    // Calculate RMS from audio frame
    let sum = 0;
    for (let i = 0; i < audioFrame.length; i++) {
      const s = audioFrame[i];
      sum += s * s;
    }
    const rms = Math.sqrt(sum / audioFrame.length);

    // Smooth with exponential moving average (α = 0.1 = responsive but not jittery)
    const alpha = 0.1;
    this.rmsSmoothed = this.rmsSmoothed * (1 - alpha) + rms * alpha;

    return this.rmsSmoothed;
  },

  // Detect speech onset/offset with hysteresis
  detectSpeech() {
    if (!this.isSpeaking && this.rmsSmoothed > this.speechStartThreshold) {
      // Speech detected (crossing up)
      this.isSpeaking = true;
      this.silenceStart = null;
      return { event: 'speech_start', rms: this.rmsSmoothed };
    }

    if (this.isSpeaking && this.rmsSmoothed < this.speechStopThreshold) {
      // Silence detected (crossing down) — start counting
      if (this.silenceStart === null) {
        this.silenceStart = performance.now();
      }

      const silenceDuration = performance.now() - this.silenceStart;
      if (silenceDuration > this.endDelayMs) {
        // Silence threshold reached — finalize
        this.isSpeaking = false;
        this.silenceStart = null;
        return { event: 'speech_end', duration: silenceDuration, rms: this.rmsSmoothed };
      }
    }

    // Still in speech or waiting for silence threshold
    return { event: 'none' };
  },

  // Load from localStorage
  load() {
    const saved = localStorage.getItem('vad-settings');
    if (saved) {
      try {
        const data = JSON.parse(saved);
        this.sensitivity = data.sensitivity || 0.5;
        this.endDelayMs = data.endDelayMs || 650;
      } catch(e) {
        // Invalid data, use defaults
      }
    }
  },

  // Save to localStorage
  save() {
    localStorage.setItem('vad-settings', JSON.stringify({
      sensitivity: this.sensitivity,
      endDelayMs: this.endDelayMs,
    }));
  },

  // Reset for new session
  reset() {
    this.rmsSmoothed = 0;
    this.isSpeaking = false;
    this.silenceStart = null;
  }
};

