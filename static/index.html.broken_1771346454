<div id="vadModal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.8);z-index:1000;align-items:center;justify-content:center;">
  <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px;width:90%;max-width:400px;box-shadow:0 20px 60px rgba(0,0,0,0.5);">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
      <h2 style="margin:0;font-size:18px;color:var(--text);">Voice Activity Detection</h2>
      <button id="vadClose" style="background:none;border:none;color:var(--text-2);cursor:pointer;font-size:24px;padding:0;">✕</button>
    </div>

    <!-- Sensitivity Slider -->
    <div style="margin-bottom:20px;">
      <label style="display:block;color:var(--text-2);font-size:12px;margin-bottom:8px;text-transform:uppercase;letter-spacing:0.5px;">
        Sensitivity: <span id="sensitivityValue" style="color:var(--accent);">50%</span>
      </label>
      <input type="range" id="sensitivitySlider" min="0" max="100" value="50"
             style="width:100%;height:4px;background:var(--border);border-radius:2px;outline:none;-webkit-appearance:none;">
      <div style="font-size:11px;color:var(--text-3);margin-top:4px;">
        ← Less sensitive (ignore quiet)  |  More sensitive (pick up whisper) →
      </div>
    </div>

    <!-- End-of-Speech Delay Slider -->
    <div style="margin-bottom:20px;">
      <label style="display:block;color:var(--text-2);font-size:12px;margin-bottom:8px;text-transform:uppercase;letter-spacing:0.5px;">
        End-of-Speech Delay: <span id="delayValue" style="color:var(--accent);">650ms</span>
      </label>
      <input type="range" id="delaySlider" min="300" max="2000" value="650" step="50"
             style="width:100%;height:4px;background:var(--border);border-radius:2px;outline:none;-webkit-appearance:none;">
      <div style="font-size:11px;color:var(--text-3);margin-top:4px;">
        ← Quick finalize (interrupt hesitation)  |  Slow finalize (allow long pauses) →
      </div>
    </div>

    <!-- Hold-to-Talk Mode -->
    <div style="margin-bottom:20px;border-top:1px solid var(--border);padding-top:16px;">
      <label style="display:flex;align-items:center;gap:8px;color:var(--text-2);font-size:12px;text-transform:uppercase;letter-spacing:0.5px;cursor:pointer;">
        <input type="checkbox" id="holdToTalkToggle" style="width:16px;height:16px;cursor:pointer;accent-color:var(--accent);">
        Hold to Talk
      </label>
      <div style="font-size:11px;color:var(--text-3);margin-top:4px;">
        When enabled, press and hold mic to speak. Release to finalize.
      </div>
    </div>

    <!-- Language Settings -->
    <div style="margin-bottom:20px;border-top:1px solid var(--border);padding-top:16px;">
      <div style="margin-bottom:12px;">
        <label style="display:block;color:var(--text-2);font-size:12px;margin-bottom:8px;text-transform:uppercase;letter-spacing:0.5px;">
          I speak:
        </label>
        <select id="sourceLanguage" style="width:100%;padding:8px;background:var(--surface2);border:1px solid var(--border);color:var(--text);border-radius:6px;font-family:inherit;">
          <option value="en">English</option>
          <option value="pt">Português (Brasil)</option>
        </select>
      </div>

      <div style="margin-bottom:12px;">
        <label style="display:block;color:var(--text-2);font-size:12px;margin-bottom:8px;text-transform:uppercase;letter-spacing:0.5px;">
          Translate to:
        </label>
        <select id="targetLanguage" style="width:100%;padding:8px;background:var(--surface2);border:1px solid var(--border);color:var(--text);border-radius:6px;font-family:inherit;">
          <option value="pt">Português (Brasil)</option>
          <option value="en">English</option>
        </select>
      </div>

      <button id="swapLanguages" style="width:100%;padding:8px;background:rgba(224,168,70,0.15);border:1px solid var(--accent);color:var(--accent);border-radius:6px;font-weight:600;cursor:pointer;font-family:inherit;">
        ↔ Swap Languages
      </button>
    </div>

    <!-- Close Button -->
    <button id="vadSave" style="width:100%;padding:12px;background:var(--accent);color:var(--bg);border:none;border-radius:6px;font-weight:600;cursor:pointer;">
      Save & Close
    </button>
  </div>
</div>

