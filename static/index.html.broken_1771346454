<script>
/* ═══════════════════════════════════════════════════════════
   FLOW CLIENT — State machine, reconnect, operator-grade
   ═══════════════════════════════════════════════════════════ */
'use strict';

const RATE = 24000;                // wire sample rate
const BACKOFF = [300,600,1200,2400,4800,8000,15000]; // exponential backoff with jitter (ms)
const MAX_BACKOFF_ATTEMPTS = 10;   // give up after 10 attempts, show "tap to reconnect"
const STABLE_MS = 2000;            // connection must hold this long to reset backoff
const KEEPALIVE_TIMEOUT_DEFAULT = 60000;   // default: if no pong in 60s, die socket
const KEEPALIVE_INTERVAL = 20000;  // client sends keepalive ping every 20s
let KEEPALIVE_TIMEOUT = KEEPALIVE_TIMEOUT_DEFAULT;  // will be updated by server
const WAVE_N = 15;                 // number of waveform bars

// ── STATE ENUM ────────────────────────────────────────────
const S = Object.freeze({
  IDLE:        'idle',
  CONNECTING:  'connecting',
  READY:       'ready',
  LISTENING:   'listening',
  TRANSLATING: 'translating',
  SPEAKING:    'speaking',
  OFFLINE:     'offline',
  FAILED:      'failed',
});

// ── APP STATE (single source of truth) ────────────────────
let state      = S.IDLE;
let ws         = null;
let audioCtx   = null;
let mediaStream= null;
let processor  = null;
let playCtx    = null;
let audioQ     = [];

// ── CLIENT-SIDE VAD (Voice Activity Detection) ────────────────────
// RMS-based endpointing with hysteresis
let vad = {
  // Settings (persisted in localStorage)
  sensitivity: 0.5,        // 0.0 (sensitive) → 1.0 (insensitive)
  endDelayMs: 650,         // silence duration before finalization

  // Runtime state
  rmsSmoothed: 0,          // smoothed RMS energy
  isSpeaking: false,       // speech detected (hysteresis)
  silenceStart: null,      // when silence began

  // Thresholds (derived from sensitivity)
  get speechStartThreshold() {
    // Lower = more sensitive. Range: 0.004 (max sensitive) → 0.015 (min sensitive)
    return 0.004 + this.sensitivity * 0.011;
  },
  get speechStopThreshold() {
    // Hysteresis: stop threshold lower than start threshold
    return this.speechStartThreshold * 0.7;
  },

  // Update RMS every frame
  updateRMS(audioFrame) {
    // Calculate RMS from audio frame
    let sum = 0;
    for (let i = 0; i < audioFrame.length; i++) {
      const s = audioFrame[i];
      sum += s * s;
    }
    const rms = Math.sqrt(sum / audioFrame.length);

    // Smooth with exponential moving average (α = 0.1 = responsive but not jittery)
    const alpha = 0.1;
    this.rmsSmoothed = this.rmsSmoothed * (1 - alpha) + rms * alpha;

    return this.rmsSmoothed;
  },

  // Detect speech onset/offset with hysteresis
  detectSpeech() {
    if (!this.isSpeaking && this.rmsSmoothed > this.speechStartThreshold) {
      // Speech detected (crossing up)
      this.isSpeaking = true;
      this.silenceStart = null;
      return { event: 'speech_start', rms: this.rmsSmoothed };
    }

    if (this.isSpeaking && this.rmsSmoothed < this.speechStopThreshold) {
      // Silence detected (crossing down) — start counting
      if (this.silenceStart === null) {
        this.silenceStart = performance.now();
      }

      const silenceDuration = performance.now() - this.silenceStart;
      if (silenceDuration > this.endDelayMs) {
        // Silence threshold reached — finalize
        this.isSpeaking = false;
        this.silenceStart = null;
        return { event: 'speech_end', duration: silenceDuration, rms: this.rmsSmoothed };
      }
    }

    // Still in speech or waiting for silence threshold
    return { event: 'none' };
  },

  // Load from localStorage
  load() {
    const saved = localStorage.getItem('vad-settings');
    if (saved) {
      try {
        const data = JSON.parse(saved);
        this.sensitivity = data.sensitivity || 0.5;
        this.endDelayMs = data.endDelayMs || 650;
      } catch(e) {
        // Invalid data, use defaults
      }
    }
  },

  // Save to localStorage
  save() {
    localStorage.setItem('vad-settings', JSON.stringify({
      sensitivity: this.sensitivity,
      endDelayMs: this.endDelayMs,
    }));
  },

  // Reset for new session
  reset() {
    this.rmsSmoothed = 0;
    this.isSpeaking = false;
    this.silenceStart = null;
  }
};

// Load VAD settings on startup
vad.load();
let playing    = false;
let peakLvl    = 0;
let waveAnim   = null;
let chunksSent = 0;

let reconnIdx  = 0;           // index into BACKOFF
let reconnTimer= null;
let stableTimer= null;
let sessionWanted = false;    // CRITICAL: default to false - user must tap mic (no auto-start on load)
let wsWanted = true;          // keep WS alive (false only after OFF)
let failedReconnectCount = 0; // track consecutive failed reconnects (grace policy)

// Reliability mode (runtime configurable)
let reliabilityMode = localStorage.getItem('reliabilityMode') || 'stable'; // 'stable' or 'fast'
let isModeSwitchRequested = false; // track if we need to send mode to server

// ── INITIALIZE RUNTIME MODE FROM QUERY PARAMS ──────────────
(function initializeMode() {
  // Check query param (?mode=stable|fast) first
  const params = new URLSearchParams(window.location.search);
  const queryMode = params.get('mode');
  if (queryMode && (queryMode === 'stable' || queryMode === 'fast')) {
    reliabilityMode = queryMode;
    localStorage.setItem('reliabilityMode', reliabilityMode);
    console.log(`[INIT] Mode from query param: ${queryMode}`);
  } else if (localStorage.getItem('reliabilityMode')) {
    reliabilityMode = localStorage.getItem('reliabilityMode');
    console.log(`[INIT] Mode from localStorage: ${reliabilityMode}`);
  } else {
    reliabilityMode = 'stable';
    localStorage.setItem('reliabilityMode', reliabilityMode);
    console.log('[INIT] Mode defaulted to: stable');
  }
})();

// Keepalive tracking (client-side timeout detection)
let lastPongTime = 0;         // timestamp of last pong received
let keepaliveTimer = null;    // checks if pong received in time
let clientKeepaliveTask = null; // sends keepalive ping every KEEPALIVE_INTERVAL

let autoScroll = true;
let audioOn    = true;
let diagOpen   = false;
let largeText  = false;
let holdToTalkMode = false;     // Must be defined at top level (referenced in turn_complete)
let isHoldingMic = false;       // Track if user is holding mic in hold-to-talk mode

let currentSrcEl  = null;
let currentTgtEl  = null;
let currentTgtTxt = '';
let sessionId      = null;      // current session ID
let sessionHistory = [];        // in-memory transcript

// ── DOM REFS ──────────────────────────────────────────────
const $app       = document.getElementById('app');
const $pill      = document.getElementById('pill');
const $pillLabel = document.getElementById('pillLabel');
const $reconnBar = document.getElementById('reconnBar');
const $reconnMsg = document.getElementById('reconnMsg');
const $reconnBtn = document.getElementById('reconnBtn');
const $transcript= document.getElementById('transcript');
const $scrollToggle = document.getElementById('scrollToggle');
const $scrollCheck  = document.getElementById('scrollCheck');
const $wave      = document.getElementById('wave');
const $micBtn    = document.getElementById('micBtn');
const $micLabel  = document.getElementById('micLabel');
const $audioBtn  = document.getElementById('audioBtn');
const $diagBtn   = document.getElementById('diagBtn');
const $diag      = document.getElementById('diag');
const $diagInner = document.getElementById('diagInner');

// build waveform bars
for (let i = 0; i < WAVE_N; i++) {
  const b = document.createElement('div');
  b.className = 'wave-bar';
  $wave.appendChild(b);
}
const waveBars = $wave.querySelectorAll('.wave-bar');

// ── HAPTIC ────────────────────────────────────────────────
function haptic(ms = 10) { navigator.vibrate && navigator.vibrate(ms); }

// ── DIAGNOSTICS LOG ───────────────────────────────────────
function diagLog(msg, type = '') {
  const ts = new Date().toLocaleTimeString('en-US', {hour12:false});
  const el = document.createElement('div');
  el.className = 'diag-line' + (type ? ' '+type : '');
  el.textContent = `[${ts}] ${msg}`;
  $diagInner.appendChild(el);
  if ($diagInner.children.length > 100) $diagInner.removeChild($diagInner.firstChild);
  $diagInner.scrollTop = $diagInner.scrollHeight;
}

// ═══════════════════════════════════════════════════════════
// STATE MACHINE — single transition point
// ═══════════════════════════════════════════════════════════
// Valid state transitions (state machine)
const VALID_TRANSITIONS = {
  [S.IDLE]:        [S.CONNECTING, S.OFFLINE],
  [S.CONNECTING]:  [S.READY, S.OFFLINE, S.FAILED],
  [S.READY]:       [S.LISTENING, S.OFFLINE, S.FAILED],
  [S.LISTENING]:   [S.TRANSLATING, S.READY, S.SPEAKING, S.OFFLINE, S.FAILED],
  [S.TRANSLATING]: [S.SPEAKING, S.READY, S.LISTENING, S.OFFLINE, S.FAILED],
  [S.SPEAKING]:    [S.READY, S.LISTENING, S.OFFLINE, S.FAILED],
  [S.OFFLINE]:     [S.CONNECTING, S.IDLE],
  [S.FAILED]:      [S.CONNECTING, S.IDLE],
};

function transition(next) {
  // Guard: no-op if already in state
  if (next === state) return;

  const prev = state;

  // CRITICAL: Validate transition is allowed
  const allowed = VALID_TRANSITIONS[prev] || [];
  if (!allowed.includes(next)) {
    diagLog(`❌ INVALID: ${prev} → ${next} (allowed: ${allowed.join(', ')})`, 'err');
    return;  // Reject invalid transition
  }

  state = next;
  diagLog(`${prev} → ${next}`, 'ok');

  // pill
  $pill.dataset.state = next;
  $pillLabel.textContent = next;

  // orb animations: set data-state for CSS animations
  $micBtn.dataset.state = next;

  // reconnect banner
  $reconnBar.classList.toggle('show', next === S.OFFLINE);

  // mic button visual
  if (next === S.OFFLINE) {
    $micBtn.dataset.vis = 'disabled';
    $micLabel.textContent = 'offline';
  } else if (next === S.IDLE) {
    $micBtn.dataset.vis = 'idle';
    $micLabel.textContent = '';
  } else if (next === S.CONNECTING) {
    $micBtn.dataset.vis = 'disabled';
    $micLabel.textContent = 'connecting';
  } else if (next === S.READY) {
    $micBtn.dataset.vis = 'idle';
    $micLabel.textContent = 'ready';
  } else if (next === S.LISTENING) {
    $micBtn.dataset.vis = 'live';
    $micLabel.textContent = 'listening';
  } else if (next === S.TRANSLATING) {
    $micBtn.dataset.vis = 'live';
    $micLabel.textContent = 'translating';
  } else if (next === S.SPEAKING) {
    $micBtn.dataset.vis = 'live';
    $micLabel.textContent = 'speaking';
  }

  // mic aria
  const isLive = [S.LISTENING, S.TRANSLATING, S.SPEAKING].includes(next);
  $micBtn.setAttribute('aria-checked', isLive);
  $micBtn.setAttribute('aria-label', isLive ? 'Stop interpreting' : 'Start interpreting');

  // waveform
  if (isLive) startWave(); else stopWave();

  // on offline/failed: stop mic cleanly
  if (next === S.OFFLINE || next === S.FAILED) {
    killMic();
    killPlayback();
  }

  // cleanup keepalive timers on disconnect states
  if (next === S.OFFLINE || next === S.FAILED || next === S.IDLE) {
    if (keepaliveTimer) { clearInterval(keepaliveTimer); keepaliveTimer = null; }
    if (clientKeepaliveTask) { clearInterval(clientKeepaliveTask); clientKeepaliveTask = null; }
  }
}

// ═══════════════════════════════════════════════════════════
// AUDIO UTILITIES
// ═══════════════════════════════════════════════════════════
function resample(inp, rateIn, rateOut) {
  if (rateIn === rateOut) return inp;
  const ratio = rateIn / rateOut;
  const len = Math.round(inp.length / ratio);
  const out = new Float32Array(len);
  for (let i = 0; i < len; i++) {
    const si = i * ratio, lo = Math.floor(si);
    const hi = Math.min(lo+1, inp.length-1), f = si - lo;
    out[i] = inp[lo]*(1-f) + inp[hi]*f;
  }
  return out;
}
function f32toI16(f32) {
  const i16 = new Int16Array(f32.length);
  for (let i = 0; i < f32.length; i++) {
    const s = Math.max(-1, Math.min(1, f32[i]));
    i16[i] = s < 0 ? s*0x8000 : s*0x7FFF;
  }
  return i16;
}
function i16toB64(i16) {
  const bytes = new Uint8Array(i16.buffer);
  const C = 8192; let bin = '';
  for (let i = 0; i < bytes.length; i += C) {
    bin += String.fromCharCode.apply(null, bytes.subarray(i, Math.min(i+C, bytes.length)));
  }
  return btoa(bin);
}
function timeStr() {
  return new Date().toLocaleTimeString('en-US', {hour12:false, hour:'2-digit', minute:'2-digit', second:'2-digit'});
}

// ═══════════════════════════════════════════════════════════
// WAVEFORM
// ═══════════════════════════════════════════════════════════
function startWave() {
  $wave.classList.add('on');
  if (waveAnim) cancelAnimationFrame(waveAnim);
  (function tick() {
    const lvl = vad.isSpeaking ? Math.min(peakLvl * 80, 24) : 2;
    for (let i = 0; i < waveBars.length; i++) {
      const h = 4 + Math.random() * Math.max(lvl, 2);
      waveBars[i].style.height = h + 'px';
    }
    waveAnim = requestAnimationFrame(tick);
  })();
}
function stopWave() {
  $wave.classList.remove('on');
  if (waveAnim) { cancelAnimationFrame(waveAnim); waveAnim = null; }
  waveBars.forEach(b => b.style.height = '4px');
}

// ═══════════════════════════════════════════════════════════
// TRANSCRIPT RENDERING
// ═══════════════════════════════════════════════════════════
function addSystemRow(text) {
  const row = document.createElement('div');
  row.className = 't-row';
  row.innerHTML = `<div class="t-cell t-system">${text}</div>`;
  $transcript.appendChild(row);
  scrollTranscript();
}
function addSourceRow(text) {
  const row = document.createElement('div');
  row.className = 't-row';
  row.innerHTML = `
    <div class="t-cell t-src">
      <span class="t-ts">${timeStr()}</span>
      <span class="t-speaker">YOU</span>
      <span class="t-text">${esc(text)}</span>
    </div>
    <div class="t-cell t-tgt" id="tgt-active">
      <span class="t-speaker">TRANSLATION</span>
    </div>`;
  $transcript.appendChild(row);
  currentSrcEl = row.querySelector('.t-src');
  currentTgtEl = row.querySelector('.t-tgt');
  currentTgtTxt = '';
  scrollTranscript();
}
function appendTranslation(delta) {
  if (!currentTgtEl) {
    // orphan delta — create a row
    const row = document.createElement('div');
    row.className = 't-row';
    row.innerHTML = `<div class="t-cell t-src"></div><div class="t-cell t-tgt streaming">
      <span class="t-speaker">TRANSLATION</span>
    </div>`;
    $transcript.appendChild(row);
    currentTgtEl = row.querySelector('.t-tgt');
    currentTgtTxt = '';
  }
  currentTgtEl.classList.add('streaming');
  currentTgtTxt += delta;

  // Remove existing text if any, keep speaker label
  let textEl = currentTgtEl.querySelector('.t-text');
  if (!textEl) {
    textEl = document.createElement('span');
    textEl.className = 't-text';
    currentTgtEl.appendChild(textEl);
  }
  textEl.textContent = currentTgtTxt;
  scrollTranscript();
}
function finishTranslation(finalText, confidence = null) {
  if (currentTgtEl) {
    currentTgtEl.classList.remove('streaming');
    if (finalText) {
      // Clear speaker label only, keep it
      const speakerEl = currentTgtEl.querySelector('.t-speaker');
      const existingText = currentTgtEl.querySelector('.t-text');
      if (existingText) existingText.remove();

      const textEl = document.createElement('span');
      textEl.className = 't-text';
      textEl.textContent = finalText;
      currentTgtEl.appendChild(textEl);

      // Add confidence if provided
      if (confidence !== null) {
        const confEl = document.createElement('span');
        confEl.className = 't-confidence';
        if (confidence >= 80) {
          confEl.classList.add('high');
          confEl.textContent = `🟢 ${confidence}%`;
        } else if (confidence >= 60) {
          confEl.classList.add('med');
          confEl.textContent = `🟡 ${confidence}%`;
        } else {
          confEl.classList.add('low');
          confEl.textContent = `🔴 ${confidence}%`;
        }
        currentTgtEl.appendChild(confEl);
      }
    }
  }
  currentSrcEl = null; currentTgtEl = null; currentTgtTxt = '';
}
function esc(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
function scrollTranscript() {
  if (autoScroll) $transcript.scrollTop = $transcript.scrollHeight;
}

// limit transcript rows
function trimTranscript() {
  while ($transcript.children.length > 60) $transcript.removeChild($transcript.firstChild);
}

// Session persistence
function initSession() {
  sessionId = 'session_' + Date.now();
  sessionHistory = [];
  try {
    localStorage.setItem('flow_current_session', sessionId);
  } catch (e) { console.warn('localStorage unavailable'); }

  // Send mode preference to server (if WebSocket ready)
  if (ws && ws.readyState === WebSocket.OPEN) {
    ws.send(JSON.stringify({
      type: 'mode_preference',
      mode: reliabilityMode
    }));
    diagLog(`Sent mode preference: ${reliabilityMode}`, 'ok');
  }
}

function saveExchange(source, target, confidence = null) {
  const exchange = { timestamp: Date.now(), source, target, confidence };
  sessionHistory.push(exchange);
  try {
    const sessions = JSON.parse(localStorage.getItem('flow_sessions') || '{}');
    if (!sessions[sessionId]) sessions[sessionId] = { started: Date.now(), exchanges: [] };
    sessions[sessionId].exchanges.push(exchange);
    localStorage.setItem('flow_sessions', JSON.stringify(sessions));
  } catch (e) { console.warn('localStorage save failed'); }
}

function loadSessionHistory() {
  try {
    const currentId = localStorage.getItem('flow_current_session');
    if (!currentId) return;
    const sessions = JSON.parse(localStorage.getItem('flow_sessions') || '{}');
    if (sessions[currentId]) {
      sessionHistory = sessions[currentId].exchanges || [];
      return sessionHistory;
    }
  } catch (e) { console.warn('localStorage load failed'); }
  return [];
}

// ═══════════════════════════════════════════════════════════
// AUDIO PLAYBACK
// ═══════════════════════════════════════════════════════════
function getPlayCtx() {
  if (!playCtx || playCtx.state === 'closed')
    playCtx = new (window.AudioContext || window.webkitAudioContext)({ sampleRate: RATE });
  return playCtx;
}
let ttsDoneNotified = false; // prevent duplicate tts_playback_done

function enqueueAudio(b64) {
  ttsDoneNotified = false;
  if (!audioOn) { notifyTTSDone(); return; }
  audioQ.push(b64);
  if (!playing) drainQ();
}
function drainQ() {
  if (!audioQ.length) { playing = false; notifyTTSDone(); return; }
  playing = true;
  const raw = atob(audioQ.shift());
  const bytes = new Uint8Array(raw.length);
  for (let i = 0; i < raw.length; i++) bytes[i] = raw.charCodeAt(i);
  const i16 = new Int16Array(bytes.buffer);
  const f32 = new Float32Array(i16.length);
  for (let i = 0; i < i16.length; i++) f32[i] = i16[i] / 32768;
  const ctx = getPlayCtx();
  const buf = ctx.createBuffer(1, f32.length, RATE);
  buf.getChannelData(0).set(f32);
  const src = ctx.createBufferSource();
  src.buffer = buf; src.connect(ctx.destination);
  src.onended = drainQ; src.start();
}
function notifyTTSDone() {
  if (ttsDoneNotified) return;
  ttsDoneNotified = true;
  if (ws && ws.readyState === WebSocket.OPEN)
    ws.send(JSON.stringify({ type: 'tts_playback_done' }));
}
function killPlayback() {
  audioQ = []; playing = false;
  ttsDoneNotified = true; // prevent stale done signal after kill
  if (playCtx && playCtx.state !== 'closed') { try { playCtx.close(); } catch(e){} playCtx = null; }
}

// ═══════════════════════════════════════════════════════════
// MICROPHONE
// ═══════════════════════════════════════════════════════════
async function startMic() {
  try {
    mediaStream = await navigator.mediaDevices.getUserMedia({
      audio: { channelCount:1, echoCancellation:true, noiseSuppression:true, autoGainControl:true }
    });
  } catch (err) {
    diagLog('Mic denied: ' + err.message, 'err');
    addSystemRow('Microphone access denied. Grant permission and try again.');
    sessionWanted = false;
    transition(S.READY);
    return;
  }
  audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  const nativeRate = audioCtx.sampleRate;
  diagLog(`Mic open: ${nativeRate}Hz → ${RATE}Hz`);
  const src = audioCtx.createMediaStreamSource(mediaStream);
  processor = audioCtx.createScriptProcessor(4096, 1, 1);

  processor.onaudioprocess = (ev) => {
    if (!ws || ws.readyState !== WebSocket.OPEN) return;
    if (state === S.OFFLINE) return;
    try {
      const inp = ev.inputBuffer.getChannelData(0);

      // ─ RMS-based VAD ─
      const rmsSmoothed = vad.updateRMS(inp);
      const vadEvent = vad.detectSpeech();

      // Log VAD events (optional, for debugging)
      if (vadEvent.event === 'speech_start') {
        diagLog(`VAD: Speech detected (RMS: ${rmsSmoothed.toFixed(4)})`, 'info');
      } else if (vadEvent.event === 'speech_end') {
        diagLog(`VAD: Silence ${vadEvent.duration.toFixed(0)}ms (RMS: ${rmsSmoothed.toFixed(4)})`, 'info');
      }

      // ─ BARGE-IN: interrupt TTS when user starts speaking ─
      if (vadEvent.event === 'speech_start' && state === S.SPEAKING) {
        diagLog('BARGE-IN: Speech detected during TTS, stopping playback', 'warn');
        killPlayback();
        // Notify server that TTS was interrupted
        if (ws && ws.readyState === WebSocket.OPEN)
          ws.send(JSON.stringify({ type: 'tts_playback_done' }));
        transition(S.LISTENING);
        haptic(10);
      }

      // ─ Peak level for waveform (unchanged) ─
      let mx = 0;
      for (let i = 0; i < inp.length; i++) { const a = Math.abs(inp[i]); if (a>mx) mx=a; }
      peakLvl = peakLvl * 0.7 + mx * 0.3;

      // Don't send audio while TTS is playing (echo suppression)
      if (state === S.SPEAKING) return;

      // Always stream audio to server while LISTENING — server has Silero VAD
      // Client VAD is only for barge-in detection and waveform viz
      if (state !== S.LISTENING) return;

      if (!ws || ws.readyState !== WebSocket.OPEN) {
        // Connection lost - let ws.onclose handle reconnection
        return;
      }

      try {
        const rs = resample(inp, nativeRate, RATE);
        ws.send(JSON.stringify({ type:'audio', audio: i16toB64(f32toI16(rs)) }));
        chunksSent++;
      } catch(e) {
        // Send failed - connection might be dead
        diagLog(`Audio send failed: ${e.message}`, 'err');
        if (ws) ws.close();  // Trigger reconnect
      }
    } catch(e) {
      // Audio processing error - log but don't crash
      diagLog(`Audio process error: ${e.message}`, 'err');
    }
  };

  src.connect(processor);
  processor.connect(audioCtx.destination);
  if (state === S.READY) transition(S.LISTENING);
}

function killMic() {
  diagLog('Cleaning up mic resources', 'info');

  if (processor) {
    try { processor.disconnect(); } catch(e){}
    processor = null;
  }
  if (audioCtx)  {
    try { audioCtx.close(); } catch(e){}
    audioCtx = null;
  }
  if (mediaStream) {
    mediaStream.getTracks().forEach(t=>t.stop());
    mediaStream = null;
  }

  chunksSent = 0;
  peakLvl = 0;
  vad.reset();  // Clear VAD state

  diagLog('Mic resources cleaned', 'ok');
}

// ═══════════════════════════════════════════════════════════
// WEBSOCKET + RECONNECT
// ═══════════════════════════════════════════════════════════

// Gate: ensures server is ready before allowing session
let serverReadyGate = false;
let isReconnecting = false;

function wsConnect() {
  // Prevent reconnect cascade
  if (isReconnecting) {
    diagLog('Already reconnecting, skipping duplicate attempt', 'info');
    return;
  }

  // guard: don't create duplicates
  if (ws && (ws.readyState === WebSocket.OPEN || ws.readyState === WebSocket.CONNECTING)) return;

  isReconnecting = true;
  transition(S.CONNECTING);

  // CRITICAL: Check if server is ready before connecting
  // (Server needs time to load Whisper, Piper, VAD, Ollama models)
  const proto = location.protocol === 'https:' ? 'https:' : 'http:';
  const healthUrl = `${proto}//${location.host}/health`;

  diagLog('Checking server health...', 'info');

  fetch(healthUrl)
    .then(r => r.json())
    .then(data => {
      if (data.status === 'ok') {
        diagLog('Server ready, connecting WebSocket...', 'ok');
        wsConnectNow();
      } else {
        diagLog(`Server not ready: ${data.status}`, 'err');
        isReconnecting = false;
        transition(S.OFFLINE);
        if (wsWanted) scheduleReconnect();
      }
    })
    .catch(err => {
      diagLog(`Health check failed: ${err.message}. Retrying...`, 'err');
      isReconnecting = false;
      transition(S.OFFLINE);
      if (wsWanted) scheduleReconnect();
    });
}

function wsConnectNow() {
  // Actually establish WebSocket connection (after health check passes)
  if (ws && (ws.readyState === WebSocket.OPEN || ws.readyState === WebSocket.CONNECTING)) return;

  const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
  const url = `${proto}//${location.host}/ws`;
  diagLog(`WebSocket connecting to ${url}`, 'ok');

  try {
    ws = new WebSocket(url);
  } catch (e) {
    diagLog(`WebSocket creation error: ${e.message}`, 'err');
    isReconnecting = false;
    transition(S.FAILED);
    if (wsWanted) scheduleReconnect();
    return;
  }

  ws.onopen = () => {
    diagLog('WebSocket open', 'ok');
    isReconnecting = false;
    lastPongTime = Date.now();

    // Start stability timer — if connection survives STABLE_MS, reset backoff
    clearTimeout(stableTimer);
    stableTimer = setTimeout(() => { reconnIdx = 0; }, STABLE_MS);

    // Start client-side keepalive check
    startClientKeepalive();

    initSession();
    // Don't transition to READY yet — wait for flow.ready from server
    // Server may need time to initialize models (Whisper, Piper, etc.)
    diagLog('WS open, awaiting flow.ready...', 'ok');
  };

  ws.onmessage = (ev) => {
    try {
      const msg = JSON.parse(ev.data);
      // Update pong timer on ANY message (to keep connection alive)
      lastPongTime = Date.now();
      handleMsg(msg);
    } catch(e) {
      diagLog('Parse error: '+e.message, 'err');
    }
  };

  ws.onerror = (ev) => {
    diagLog('⚠️ WebSocket error event', 'err');
    diagLog(`Error details: ${JSON.stringify(ev)}`, 'err');
    // Don't close here - let onclose handle it
    // Closing might cause duplicate handling
  };

  ws.onclose = (ev) => {
    // If we intentionally stopped, don't reconnect
    if (stopInProgress) {
      diagLog('Stop in progress, skipping reconnect logic in ws.onclose', 'info');
      ws = null;
      return;
    }

    clearTimeout(stableTimer);
    if (keepaliveTimer) { clearInterval(keepaliveTimer); keepaliveTimer = null; }
    if (clientKeepaliveTask) { clearInterval(clientKeepaliveTask); clientKeepaliveTask = null; }
    isReconnecting = false;

    // WebSocket telemetry
    const closeCode = ev.code;
    const closeReason = ev.reason || '(no reason)';
    const tabVisible = !document.hidden;
    const navigatorOnline = navigator.onLine;

    diagLog(`🔌 WS closed: code=${closeCode} reason='${closeReason}'`, 'err');
    diagLog(`Telemetry: visible=${tabVisible}, navigator.onLine=${navigatorOnline}`, 'info');
    diagLog(`Reconnect progress: ${reconnIdx}/${MAX_BACKOFF_ATTEMPTS}`, 'info');

    ws = null;

    // Code 1000 = clean close (user initiated)
    if (closeCode === 1000) {
      transition(S.IDLE);
      failedReconnectCount = 0;
      diagLog('Clean close (user initiated)', 'ok');
      return;
    }

    // Code 1006 = abnormal closure (usually network error or server crash)
    if (closeCode === 1006) {
      diagLog('Abnormal closure (network error or server restart)', 'err');
    }

    // Any other close = unexpected, try to reconnect
    killMic();

    // Grace policy: require 2 consecutive failed reconnect attempts before FAILED state
    // This prevents showing "offline failed" on every one-off network hiccup
    if (reconnIdx >= MAX_BACKOFF_ATTEMPTS) {
      failedReconnectCount++;
      if (failedReconnectCount >= 2) {
        transition(S.FAILED); // give up after 2 consecutive failures
        diagLog('Max reconnect attempts reached (2 consecutive failures)', 'err');
      } else {
        transition(S.OFFLINE);
        diagLog(`Failed reconnect ${failedReconnectCount}/2 before FAILED state`, 'warn');
      }
    } else {
      failedReconnectCount = 0; // Reset on new reconnect attempt
      transition(S.OFFLINE);
      diagLog(`Attempting to reconnect (attempt ${reconnIdx + 1}/${MAX_BACKOFF_ATTEMPTS})`, 'info');
    }

    if (wsWanted) scheduleReconnect();
  };
}

// Start client-side keepalive: expects pong within KEEPALIVE_TIMEOUT
function startClientKeepalive() {
  if (clientKeepaliveTask) clearInterval(clientKeepaliveTask);
  lastPongTime = Date.now();

  // Send keepalive ping every 20s
  clientKeepaliveTask = setInterval(() => {
    if (!ws || ws.readyState !== WebSocket.OPEN) return;
    try {
      ws.send(JSON.stringify({ type: 'keepalive_ping' }));
    } catch (e) {
      diagLog(`Keepalive ping failed: ${e.message}`, 'err');
    }
  }, KEEPALIVE_INTERVAL);

  // Check if pong received within timeout
  if (keepaliveTimer) clearInterval(keepaliveTimer);
  keepaliveTimer = setInterval(() => {
    const timeSinceLastPong = Date.now() - lastPongTime;
    if (timeSinceLastPong > KEEPALIVE_TIMEOUT) {
      diagLog(`Keepalive timeout: no pong in ${KEEPALIVE_TIMEOUT}ms, killing socket`, 'err');
      if (ws) ws.close();
    }
  }, KEEPALIVE_TIMEOUT / 2); // check every half the timeout
}

function scheduleReconnect() {
  clearTimeout(reconnTimer);

  // Cap attempts at MAX_BACKOFF_ATTEMPTS
  if (reconnIdx >= MAX_BACKOFF_ATTEMPTS) {
    $reconnMsg.textContent = `Connection failed. Tap to reconnect.`;
    diagLog(`Reconnect capped at ${MAX_BACKOFF_ATTEMPTS} attempts`, 'err');
    return;
  }

  // Exponential backoff from BACKOFF array
  const baseDelay = BACKOFF[Math.min(reconnIdx, BACKOFF.length - 1)];

  // Add jitter: ±25% randomness to prevent thundering herd
  const jitter = baseDelay * (0.75 + Math.random() * 0.5);
  const delay = Math.round(jitter);

  // Reduce aggressiveness if tab hidden (be nice to background tabs)
  const effectiveDelay = document.hidden ? delay * 3 : delay;

  $reconnMsg.textContent = `Reconnecting in ${(effectiveDelay/1000).toFixed(1)}s\u2026`;
  diagLog(`Reconnect in ${effectiveDelay}ms (attempt ${reconnIdx+1}/${MAX_BACKOFF_ATTEMPTS})`);

  reconnTimer = setTimeout(() => {
    reconnIdx++;
    isReconnecting = false; // allow wsConnect to proceed
    wsConnect();
  }, effectiveDelay);
}

function forceReconnect() {
  clearTimeout(reconnTimer);
  reconnIdx = 0;
  isReconnecting = false;
  failedReconnectCount = 0;
  diagLog('Manual reconnect', 'ok');
  wsConnect();
}

// ═══════════════════════════════════════════════════════════
// MESSAGE HANDLER
// ═══════════════════════════════════════════════════════════
function handleMsg(msg) {
  switch (msg.type) {
    case 'flow.ready':
      // Update keepalive timeout from server (Stable: 90s, Fast: 45s)
      if (msg.keepalive_timeout_ms) {
        KEEPALIVE_TIMEOUT = msg.keepalive_timeout_ms;
        diagLog(`Server ready: mode=${msg.reliability_mode} (keepalive: ${KEEPALIVE_TIMEOUT}ms)`);
      }
      serverReadyGate = true;

      // CRITICAL: Enforce single mode source of truth - send client's mode preference immediately
      // This prevents mode mismatch (server defaults to 'fast', client wants 'stable')
      if (ws && ws.readyState === WebSocket.OPEN) {
        ws.send(JSON.stringify({
          type: 'mode_preference',
          mode: reliabilityMode
        }));
        diagLog(`Enforcing mode: ${reliabilityMode}`, 'ok');
      }

      transition(S.READY);
      reconnIdx = 0;
      failedReconnectCount = 0;
      haptic(20);
      // Note: Do NOT auto-start mic (sessionWanted is false by default)
      break;

    case 'mode_confirmed':
      // Server acknowledged mode preference and applied it
      if (msg.keepalive_timeout_ms) {
        KEEPALIVE_TIMEOUT = msg.keepalive_timeout_ms;
        diagLog(`Mode confirmed: ${msg.reliability_mode} (keepalive: ${KEEPALIVE_TIMEOUT}ms)`, 'ok');
      }
      break;

    case 'ping':
      // respond to server keepalive
      lastPongTime = Date.now();
      if (ws && ws.readyState === WebSocket.OPEN)
        ws.send(JSON.stringify({ type:'pong' }));
      break;

    case 'pong':
      // server responds to client keepalive
      lastPongTime = Date.now();
      break;

    case 'keepalive_pong':
      // explicit keepalive response
      lastPongTime = Date.now();
      break;

    case 'speech_started':
      transition(S.LISTENING); // confirm listening state
      haptic();
      break;

    case 'speech_stopped':
      if (state === S.LISTENING) transition(S.TRANSLATING);
      break;

    case 'source_transcript':
      addSourceRow(msg.text);
      trimTranscript();
      break;

    case 'translation_delta':
      appendTranslation(msg.text);
      break;

    case 'translation_done': {
      // Save before finishTranslation clears refs
      const srcEl = currentSrcEl;
      const tgtTxt = currentTgtTxt;
      finishTranslation(msg.text, msg.confidence);
      if (srcEl) {
        const srcText = srcEl.querySelector('.t-text')?.textContent || '';
        saveExchange(srcText, msg.text || tgtTxt, msg.confidence);
      }
      break;
    }

    case 'tts_start':
      transition(S.SPEAKING);
      break;

    case 'audio_delta':
      if (state !== S.SPEAKING) transition(S.SPEAKING);
      enqueueAudio(msg.audio);
      break;

    case 'turn_complete':
      finishTranslation();
      // Auto-resume listening if NOT in hold-to-talk mode
      const nextState = holdToTalkMode ? S.READY : S.LISTENING;
      transition(nextState);
      // Auto-restart mic for next turn if user wants a live session
      if (sessionWanted && !mediaStream) startMic();
      break;

    case 'error':
      addSystemRow(msg.message || 'Unknown error');
      diagLog(msg.message || 'Server error', 'err');
      // stay in current state, don't crash
      break;

    default:
      diagLog(`Unknown msg: ${msg.type}`);
  }
}

// ═══════════════════════════════════════════════════════════
// USER ACTIONS
// ═══════════════════════════════════════════════════════════
let stopInProgress = false;
let startInProgress = false;   // P0: Prevent double-tap start flapping
let restartInProgress = false;
let restartTimeout = null;
let lastStartAttempt = 0;      // P0: Debounce mic start (250ms minimum interval)

function softStop() {
  if (stopInProgress) {
    diagLog('Stop already in progress, ignoring', 'warn');
    return;
  }

  stopInProgress = true;
  try {
    diagLog('Session paused (soft stop)', 'info');
    killMic();
    killPlayback();
    sessionWanted = false;

    // Clear restart timeout if pending
    clearTimeout(restartTimeout);
    restartTimeout = null;
    restartInProgress = false;

    // Keep WebSocket open, just pause session
    transition(S.READY);
    haptic(20);
  } finally {
    stopInProgress = false;
  }
}

function startSession() {
  // P0: MIC BUTTON = START ONLY (IDEMPOTENT)
  // If already listening/translating/speaking, IGNORE the click (do not stop)
  if ([S.LISTENING, S.TRANSLATING, S.SPEAKING].includes(state)) {
    diagLog('Mic click ignored during active session', 'info');
    return;
  }

  // P0: Debounce mic start (absorb double taps within 250ms)
  const now = Date.now();
  if (now - lastStartAttempt < 250) {
    diagLog('Mic click debounced (double tap)', 'info');
    return;
  }
  lastStartAttempt = now;

  // Reject if start/stop already in progress (avoid race)
  if (startInProgress || stopInProgress) {
    diagLog('Start/stop already in progress, ignoring', 'warn');
    return;
  }

  // Wait while connecting
  if (state === S.CONNECTING) {
    diagLog('Connecting, please wait...', 'info');
    return;
  }

  // START from READY: Start mic immediately (WebSocket already open)
  if (state === S.READY && serverReadyGate) {
    startInProgress = true;
    sessionWanted = true;
    haptic(20);
    diagLog('Starting mic...', 'info');
    startMic();
    startInProgress = false;
    return;
  }

  // RESTART from OFFLINE/IDLE: Reconnect first
  if (state === S.IDLE || state === S.OFFLINE || state === S.FAILED) {
    if (restartInProgress) {
      diagLog('Restart already in progress', 'warn');
      return;
    }

    restartInProgress = true;
    sessionWanted = true;
    wsWanted = true;
    haptic(20);

    // Show feedback message
    $reconnMsg.textContent = 'Reconnecting...';
    diagLog('Restarting connection...', 'info');

    // Timeout: if no flow.ready within 3s, show retry
    clearTimeout(restartTimeout);
    restartTimeout = setTimeout(() => {
      if (!serverReadyGate) {
        diagLog('Restart timeout: no server response in 3s', 'err');
        $reconnMsg.textContent = 'Connection timeout. Tap to retry.';
        restartInProgress = false;
      }
    }, 3000);

    forceReconnect();
    return;
  }

  // Other states: log and wait
  diagLog(`Cannot start from state: ${state}`, 'warn');
}

$micBtn.addEventListener('click', startSession);

// keyboard: Space or Enter on mic button
$micBtn.addEventListener('keydown', (e) => {
  if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); startSession(); }
});

// reconnect button
$reconnBtn.addEventListener('click', () => {
  wsWanted = true;
  sessionWanted = true;
  forceReconnect();
});

// audio toggle
$audioBtn.addEventListener('click', () => {
  audioOn = !audioOn;
  $audioBtn.classList.toggle('on', audioOn);
  $audioBtn.setAttribute('aria-pressed', audioOn);
  haptic();
});

// diag toggle
$diagBtn.addEventListener('click', () => {
  diagOpen = !diagOpen;
  $diag.classList.toggle('open', diagOpen);
  $diagBtn.classList.toggle('on', diagOpen);
  $diagBtn.setAttribute('aria-pressed', diagOpen);
  haptic();
});

// manual OFF button - soft stop (pause session without closing WebSocket)
const $offBtn = document.getElementById('offBtn');
if ($offBtn) {
  $offBtn.addEventListener('click', () => {
    diagLog('OFF button: soft stop', 'info');
    softStop();
    haptic(30);
  });
}

// autoscroll toggle
$scrollToggle.addEventListener('click', () => {
  autoScroll = !autoScroll;
  $scrollCheck.textContent = autoScroll ? '\u2713' : '';
  $scrollToggle.setAttribute('aria-pressed', autoScroll);
});

// ── cleanup on unload ─────────────────────────────────────
window.addEventListener('beforeunload', () => {
  sessionWanted = false;
  wsWanted = false;
  killMic(); killPlayback();
  if (ws) { ws.close(1000, 'page unload'); ws = null; }
});

// ── visibility change: reduce reconnect aggressiveness ────
document.addEventListener('visibilitychange', () => {
  if (document.visibilityState === 'visible' && state === S.OFFLINE && wsWanted && !stopInProgress) {
    forceReconnect();
  }
});

// ── Wake Lock ─────────────────────────────────────────────
let wakeLock = null;
async function acquireWake() {
  try {
    if ('wakeLock' in navigator) wakeLock = await navigator.wakeLock.request('screen');
  } catch(e) {}
}
document.addEventListener('visibilitychange', () => {
  if (document.visibilityState === 'visible' && [S.LISTENING, S.TRANSLATING, S.SPEAKING].includes(state))
    acquireWake();
});

// ── Lifecycle: Visibility (backgrounding/foregrounding) ────
document.addEventListener('visibilitychange', () => {
  if (document.visibilityState === 'visible') {
    // App came to foreground
    diagLog('App foreground', 'ok');
    if ((state === S.OFFLINE || state === S.FAILED) && !stopInProgress) {
      if (wsWanted) {
        reconnIdx = 0; // reset backoff on user return
        forceReconnect();
      }
    }
  } else {
    // App backgrounded — make reconnects less aggressive
    diagLog('App background', 'ok');
  }
});

// ── Lifecycle: Online/Offline status ────
window.addEventListener('online', () => {
  diagLog('Network online', 'ok');
  if (state === S.OFFLINE && wsWanted && !stopInProgress) {
    reconnIdx = 0;
    forceReconnect();
  }
});

window.addEventListener('offline', () => {
  diagLog('Network offline', 'err');
  transition(S.OFFLINE);
});

// ── Service Worker ────────────────────────────────────────
if ('serviceWorker' in navigator) navigator.serviceWorker.register('/static/sw.js').catch(()=>{});

// ── Initial log ───────────────────────────────────────────
diagLog('Flow client loaded');

// ── Auto-connect WebSocket on load ───────────────────────
// Connect immediately so user sees READY state; mic starts on user tap
wsConnect();
</script>

