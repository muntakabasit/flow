  width: 16px;
  height: 16px;
  background: var(--accent);
  border-radius: 50%;
  cursor: pointer;
  border: none;
  box-shadow: 0 2px 8px rgba(224, 168, 70, 0.3);
}
</style>

<script>
// ─ VAD Settings UI ─
const $vadModal = document.getElementById('vadModal');
const $sensitivitySlider = document.getElementById('sensitivitySlider');
const $delaySlider = document.getElementById('delaySlider');
const $sensitivityValue = document.getElementById('sensitivityValue');
const $delayValue = document.getElementById('delayValue');
const $settingsBtn = document.getElementById('settingsBtn');
const $vadClose = document.getElementById('vadClose');
const $vadSave = document.getElementById('vadSave');

// DEBUG: Log what we found
console.log('VAD UI Elements:', {
  settingsBtn: !!$settingsBtn,
  vadModal: !!$vadModal,
  sensitivitySlider: !!$sensitivitySlider,
  delaySlider: !!$delaySlider,
  vadClose: !!$vadClose,
  vadSave: !!$vadSave
});

// Guard: only run if all elements exist
if ($settingsBtn && $vadModal && $sensitivitySlider && $delaySlider) {
  console.log('VAD Settings UI: Initializing event listeners...');
  // Update slider display (define FIRST before calling)
  function updateSliderDisplay() {
    const sens = parseInt($sensitivitySlider.value);
    const delay = parseInt($delaySlider.value);
    $sensitivityValue.textContent = sens + '%';
    $delayValue.textContent = delay + 'ms';
  }

  // Open settings
  $settingsBtn.addEventListener('click', () => {
    $sensitivitySlider.value = Math.round(vad.sensitivity * 100);
    $delaySlider.value = vad.endDelayMs;
    updateSliderDisplay();
    $vadModal.style.display = 'flex';
  });

  // Close settings
  const closeSettings = () => {
    $vadModal.style.display = 'none';
  };

  $vadClose.addEventListener('click', closeSettings);
  $vadSave.addEventListener('click', () => {
    vad.sensitivity = parseInt($sensitivitySlider.value) / 100;
    vad.endDelayMs = parseInt($delaySlider.value);
    vad.save();
    diagLog(`VAD: Sensitivity=${(vad.sensitivity*100).toFixed(0)}%, Delay=${vad.endDelayMs}ms`, 'ok');
    closeSettings();
  });

  $sensitivitySlider.addEventListener('input', updateSliderDisplay);
  $delaySlider.addEventListener('input', updateSliderDisplay);

  // ──── HOLD-TO-TALK MODE ────
  const $holdToTalkToggle = document.getElementById('holdToTalkToggle');
  // Initialize from localStorage (holdToTalkMode and isHoldingMic are now top-level)
  holdToTalkMode = localStorage.getItem('holdToTalkMode') === 'true';

  if ($holdToTalkToggle) {
    $holdToTalkToggle.checked = holdToTalkMode;

    $holdToTalkToggle.addEventListener('change', (e) => {
      holdToTalkMode = e.target.checked;
      localStorage.setItem('holdToTalkMode', holdToTalkMode ? 'true' : 'false');
      diagLog(`Hold-to-Talk: ${holdToTalkMode ? 'ON' : 'OFF'}`, 'info');
    });

    // Mouse events for desktop
    const originalMouseDown = (e) => {
      if (!holdToTalkMode) return;
      isHoldingMic = true;
      e.preventDefault();
      if (state === S.READY || state === S.IDLE) startSession();
    };

    const originalMouseUp = (e) => {
      if (!holdToTalkMode || !isHoldingMic) return;
      isHoldingMic = false;
      e.preventDefault();
      if (state === S.LISTENING) {
        killMic();
        diagLog('Hold released, finalizing turn', 'info');
      }
    };

    $micBtn.addEventListener('mousedown', originalMouseDown);
    document.addEventListener('mouseup', originalMouseUp);

    // Touch events for mobile
    $micBtn.addEventListener('touchstart', (e) => {
      if (!holdToTalkMode) return;
      isHoldingMic = true;
      if (state === S.READY || state === S.IDLE) startSession();
    });

    $micBtn.addEventListener('touchend', (e) => {
      if (!holdToTalkMode || !isHoldingMic) return;
      isHoldingMic = false;
      if (state === S.LISTENING) {
        killMic();
        diagLog('Touch released, finalizing turn', 'info');
      }
    });
  }

  // ──── LANGUAGE SETTINGS ────
  const $sourceLanguage = document.getElementById('sourceLanguage');
  const $targetLanguage = document.getElementById('targetLanguage');
  const $swapLanguages = document.getElementById('swapLanguages');

  let sourceLanguage = localStorage.getItem('sourceLanguage') || 'en';
  let targetLanguage = localStorage.getItem('targetLanguage') || 'pt';

  // Load saved language preferences
  if ($sourceLanguage) $sourceLanguage.value = sourceLanguage;
  if ($targetLanguage) $targetLanguage.value = targetLanguage;

  // Send language config to server
  function sendLanguageToServer() {
    if (ws && ws.readyState === WebSocket.OPEN) {
      ws.send(JSON.stringify({
        type: 'language_config',
        source_language: sourceLanguage,
        target_language: targetLanguage
      }));
      diagLog(`Language config sent: ${sourceLanguage} → ${targetLanguage}`, 'ok');
    }
  }

  // Update UI language display
  function updateLanguageDisplay() {
    const langNames = { 'en': 'English', 'pt': 'Português' };
    const $langBar = document.querySelector('.lang-bar');
    if ($langBar) {
      $langBar.innerHTML = `<span class="lang-tag">${langNames[sourceLanguage] || 'English'}</span><span class="lang-arrow">&#8644;</span><span class="lang-tag">${langNames[targetLanguage] || 'Português'}</span>`;
    }
  }

  if ($sourceLanguage) {
    $sourceLanguage.addEventListener('change', (e) => {
      sourceLanguage = e.target.value;
      localStorage.setItem('sourceLanguage', sourceLanguage);
      updateLanguageDisplay();
      sendLanguageToServer();
    });
  }

  if ($targetLanguage) {
    $targetLanguage.addEventListener('change', (e) => {
      targetLanguage = e.target.value;
      localStorage.setItem('targetLanguage', targetLanguage);
      updateLanguageDisplay();
      sendLanguageToServer();
    });
  }

  if ($swapLanguages) {
    $swapLanguages.addEventListener('click', () => {
      [sourceLanguage, targetLanguage] = [targetLanguage, sourceLanguage];
      if ($sourceLanguage) $sourceLanguage.value = sourceLanguage;
      if ($targetLanguage) $targetLanguage.value = targetLanguage;
      localStorage.setItem('sourceLanguage', sourceLanguage);
      localStorage.setItem('targetLanguage', targetLanguage);
      updateLanguageDisplay();
      sendLanguageToServer();
      diagLog(`Languages swapped: ${sourceLanguage} ↔ ${targetLanguage}`, 'info');
    });
  }

  // Update language display on init
  updateLanguageDisplay();

  // Close on backdrop click
  $vadModal.addEventListener('click', (e) => {
    if (e.target === $vadModal) closeSettings();
  });
}

// ══════════════════════════════════════════════════════════════
// MODE B: TRANSCRIPT COLLAPSE + RMS INTENSITY
// ══════════════════════════════════════════════════════════════

(function modeB() {
  const $transcriptWrap = document.querySelector('.transcript-wrap');
  const $toolbar = document.querySelector('.transcript-toolbar');
  const $transcript = document.getElementById('transcript');

  if (!$transcriptWrap || !$toolbar) return;

  // Initialize collapse state from localStorage
  let isCollapsed = localStorage.getItem('transcriptCollapsed') === 'true';
  $transcriptWrap.setAttribute('data-collapsed', isCollapsed);

  // Replace "Transcript" label with History button
  const $label = $toolbar.querySelector('span');
  if ($label) {
    const $historyBtn = document.createElement('button');
    $historyBtn.id = 'historyToggle';
    $historyBtn.className = 'history-toggle';
    $historyBtn.innerHTML = '📜 History <span id="msgCount">(0)</span>';
    $historyBtn.style.cssText = 'font-size:10px; color:var(--accent); cursor:pointer; background:none; border:none; font-family:var(--font); font-weight:600; letter-spacing:0.5px; padding:4px 8px; border-radius:4px; transition:all 0.2s;';

    $historyBtn.addEventListener('mouseover', () => {
      $historyBtn.style.background = 'rgba(224,168,70,0.1)';
    });
    $historyBtn.addEventListener('mouseout', () => {
      $historyBtn.style.background = 'none';
    });

    $historyBtn.addEventListener('click', () => {
      isCollapsed = !isCollapsed;
      localStorage.setItem('transcriptCollapsed', isCollapsed);
      $transcriptWrap.setAttribute('data-collapsed', isCollapsed);
      haptic();
    });

    $label.replaceWith($historyBtn);
  }

  // Update message count
  function updateMessageCount() {
    const rows = $transcript.querySelectorAll('.t-row');
    const count = rows.length;
    const $count = document.getElementById('msgCount');
    if ($count) $count.textContent = `(${count})`;
  }

  // Observer for new messages
  const observer = new MutationObserver(updateMessageCount);
  observer.observe($transcript, { childList: true });
  updateMessageCount();

  // RMS intensity: Feed peakLvl to CSS variable
  // This creates the dynamic glow effect tied to voice energy
  setInterval(() => {
    const intensity = Math.min(peakLvl / 100, 1); // Normalize 0-1
    document.documentElement.style.setProperty('--rms-intensity', intensity);
  }, 50);

  diagLog('MODE B UI initialized', 'info');
})();

</script>

</body>
